# Confluence Cloud base URL, no trailing slash. Example: https://yourorg.atlassian.net
CONFLUENCE_BASE_URL=

# Atlassian account email. REQUIRED for classic tokens (Basic auth).
# Leave empty if using a scoped API token (Bearer auth).
CONFLUENCE_EMAIL=

# API token from https://id.atlassian.com/manage-profile/security/api-tokens
CONFLUENCE_API_TOKEN=

# Auth mode: auto | basic | bearer
#   auto   - bearer if CONFLUENCE_EMAIL empty, else basic (default)
#   basic  - classic API token + email
#   bearer - scoped API token (with scopes like read:page:confluence)
CONFLUENCE_AUTH=auto

# Either a space key (e.g. ENG) or a root page id. Root page wins if both set.
CONFLUENCE_SPACE_KEY=
CONFLUENCE_ROOT_PAGE_ID=
